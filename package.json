{
  "name": "@nordio/brreg-mcp-server",
  "version": "0.1.3",
  "description": "Norwegian business register (Brønnøysundregistrene) as an MCP server — companies, roles, subunits and annual accounts, with the register's silent traps encoded as guards.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nordio-ai/brreg-mcp-server.git"
  },
  "homepage": "https://github.com/nordio-ai/brreg-mcp-server#readme",
  "bugs": "https://github.com/nordio-ai/brreg-mcp-server/issues",
  "bin": {
    "brreg-mcp-server": "dist/stdio.js",
    "brreg-mcp": "dist/stdio.js",
    "brreg": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/stdio.ts",
    "dev:mock": "tsx src/stdio.ts --mock",
    "cli": "tsx src/cli.ts",
    "inspect": "MOCK=1 npx @modelcontextprotocol/inspector tsx src/stdio.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "build": "tsc -p tsconfig.json",
    "bundle": "node bin/bundle.mjs",
    "nace:build": "node bin/build-nace.mjs > src/nace-table.ts",
    "version": "node bin/sync-version.mjs && git add manifest.json"
  },
  "dependencies": {
    "@nordio/server-kit": "0.8.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@types/node": "20.14.15",
    "tsx": "4.23.1",
    "typescript": "5.5.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "tmp": "^0.2.7"
  }
}
